{
  "rules": [
    {
      "id": "Default Multipart Abort Rule",
      "enabled": true,
      "conditions": {
        "prefix": ""
      },
      "abortMultipartUploadsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 604800
        }
      }
    },
    {
      "id": "delete-print-staging-after-seven-days",
      "enabled": true,
      "conditions": {
        "prefix": "print-staging/"
      },
      "deleteObjectsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 604800
        }
      }
    }
  ]
}
