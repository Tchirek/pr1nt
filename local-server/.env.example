# pr1nt local print server configuration.
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# --- Network ---
# Public intake server (reached via the Cloudflare Tunnel). Binds all interfaces.
PUBLIC_BIND_ADDR=0.0.0.0:8788
# Local admin server. Keep this on loopback only.
ADMIN_BIND_ADDR=127.0.0.1:8789

# --- Auth (shared with the Worker / admin UI) ---
# Must match the Worker's PRINT_SHARED_SECRET.
PRINT_SHARED_SECRET=change-me-shared-secret
# Token the local admin UI uses to call the admin API.
LOCAL_ADMIN_TOKEN=change-me-admin-token

# --- Printing toolchain ---
# Path to SumatraPDF.exe (see local-server/bin/README.md).
SUMATRA_PDF_PATH=SumatraPDF
# Friendly names of the installed printers, as shown by `wmic printer get name`.
BW_PRINTER_NAME=HP LaserJet 1022
COLOR_PRINTER_NAME=Canon TS3300

# --- Local paths (resolved relative to the executable) ---
LOCAL_RUNTIME_CONFIG_PATH=./runtime-config.json
PRINT_STORAGE_DIR=./print-spool
ADMIN_STATIC_DIR=../local-admin

# --- Default pricing / payment / notice (overridable from the admin UI) ---
DEFAULT_BW_PRICE=0.2
DEFAULT_COLOR_PRICE=1.0
DEFAULT_ALIPAY_QR=
DEFAULT_WECHAT_QR=
DEFAULT_NOTICE_MARKDOWN=

# --- Cloudflare KV sync (optional; leave blank to disable remote config sync) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# --- R2 pull sync (optional; leave blank to disable the print-sync worker pull) ---
PRINT_WORKER_BASE_URL=
PRINT_SYNC_SECRET=
# Stable identifiers for this machine (auto-derived from hostname if omitted).
PRINT_SYNC_DEVICE_ID=
PRINT_SYNC_INSTANCE_ID=

# --- Legacy tunnel upload routes (disabled by default; bytes would traverse the tunnel) ---
LEGACY_TUNNEL_UPLOAD_ENABLED=false
